{
  "name": "programa-vmc",
  "productName": "Programa VMC",
  "description": "Organización de la reunión Vida y Ministerio Cristianos",
  "author": "Carlos Parra Martínez",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "main": "electron/main.cjs",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "desktop:dev": "concurrently -k \"vite --host localhost\" \"wait-on http://localhost:5173 && electron .\"",
    "desktop:preview": "npm run build && electron .",
    "desktop:build": "npm run build && electron-builder --win nsis",
    "lint": "eslint .",
    "preview": "vite preview"
  },
  "dependencies": {
    "@tailwindcss/vite": "^4.1.17",
    "firebase": "^12.6.0",
    "framer-motion": "^12.23.25",
    "jotai": "^2.15.2",
    "pdfjs-dist": "^6.1.200",
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "react-hot-toast": "^2.6.0",
    "react-router-dom": "^7.10.1",
    "sass": "^1.94.2",
    "tailwindcss": "^4.1.17",
    "uuid": "^13.0.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.1",
    "@types/react": "^19.2.5",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react-swc": "^4.2.2",
    "concurrently": "^9.2.4",
    "electron": "^43.2.0",
    "electron-builder": "^26.15.3",
    "eslint": "^9.39.1",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.4.24",
    "globals": "^16.5.0",
    "png-to-ico": "^3.0.2",
    "sharp": "^0.35.3",
    "vite": "npm:rolldown-vite@7.2.5",
    "wait-on": "^9.1.0"
  },
  "overrides": {
    "vite": "npm:rolldown-vite@7.2.5"
  },
  "build": {
    "appId": "com.programavmc.desktop",
    "productName": "Programa VMC",
    "asar": true,
    "npmRebuild": false,
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/**/*",
      "electron/**/*",
      "package.json",
      "!node_modules/**/*"
    ],
    "win": {
      "icon": "build/icon.ico",
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        }
      ],
      "artifactName": "${productName}-Setup-${version}.${ext}"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "Programa VMC"
    }
  }
}
